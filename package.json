    "db:seed": "ts-node src/database/seed.ts",
    "db:seed:large": "ts-node src/database/seed_large.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
