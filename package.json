{
  "name": "pharmacy-backend",
  "version": "1.0.0",
  "description": "Pharmacy Management System Backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
